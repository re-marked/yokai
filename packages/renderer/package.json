{
  "name": "@yokai/renderer",
  "version": "0.5.0",
  "description": "React terminal renderer — reconciler + Yoga layout + TTY output",
  "license": "MIT",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "lint": "biome check src/"
  },
  "dependencies": {
    "@alcalzone/ansi-tokenize": "^0.3.0",
    "@yokai/shared": "workspace:*",
    "auto-bind": "^5.0.1",
    "bidi-js": "^1.0.3",
    "chalk": "^5.6.2",
    "cli-boxes": "^4.0.1",
    "code-excerpt": "^4.0.0",
    "emoji-regex": "^10.6.0",
    "get-east-asian-width": "^1.5.0",
    "indent-string": "^5.0.0",
    "semver": "^7.7.4",
    "signal-exit": "^4.1.0",
    "stack-utils": "^2.0.6",
    "strip-ansi": "^7.2.0",
    "supports-hyperlinks": "^4.4.0",
    "type-fest": "^5.6.0",
    "usehooks-ts": "^3.1.1",
    "wrap-ansi": "^10.0.0"
  },
  "peerDependencies": {
    "react": ">=19.0.0",
    "react-reconciler": ">=0.33.0"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/preset-react": "^7.28.5",
    "@babel/preset-typescript": "^7.28.5",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-reconciler": "0.33.0",
    "babel-plugin-react-compiler": "^1.0.0",
    "esbuild-plugin-babel": "^0.2.3",
    "react": "^19.2.5",
    "react-reconciler": "^0.33.0",
    "tsup": "^8.5.1",
    "typescript": "~6.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/re-marked/yokai.git",
    "directory": "packages/renderer"
  },
  "homepage": "https://github.com/re-marked/yokai",
  "bugs": "https://github.com/re-marked/yokai/issues",
  "keywords": [
    "terminal",
    "cli",
    "tui",
    "react",
    "renderer",
    "yoga"
  ],
  "engines": {
    "node": ">=22.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
