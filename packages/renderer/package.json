{
  "name": "@yokai/renderer",
  "version": "0.3.0",
  "description": "React terminal renderer — reconciler + Yoga layout + TTY output",
  "license": "MIT",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "lint": "biome check src/"
  },
  "dependencies": {
    "@alcalzone/ansi-tokenize": "*",
    "@yokai/shared": "workspace:*",
    "auto-bind": "*",
    "bidi-js": "*",
    "chalk": "*",
    "cli-boxes": "*",
    "code-excerpt": "*",
    "emoji-regex": "*",
    "get-east-asian-width": "*",
    "indent-string": "*",
    "semver": "*",
    "signal-exit": "*",
    "stack-utils": "*",
    "strip-ansi": "*",
    "supports-hyperlinks": "*",
    "type-fest": "*",
    "usehooks-ts": "*",
    "wrap-ansi": "*"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-reconciler": ">=0.29.0"
  },
  "devDependencies": {
    "@types/node": "*",
    "@types/react": "*",
    "@types/react-reconciler": "0.33.0",
    "react": "*",
    "react-reconciler": "*",
    "tsup": "*",
    "typescript": "*"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/re-marked/yokai.git",
    "directory": "packages/renderer"
  },
  "homepage": "https://github.com/re-marked/yokai",
  "bugs": "https://github.com/re-marked/yokai/issues",
  "keywords": [
    "terminal",
    "cli",
    "tui",
    "react",
    "renderer",
    "yoga"
  ],
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  }
}
