{
  "name": "@yokai/shared",
  "version": "0.5.1",
  "description": "Shared utilities — Yoga layout TS port, logger, env helpers",
  "license": "MIT",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./yoga-layout": {
      "types": "./dist/yoga-layout/index.d.ts",
      "import": "./dist/yoga-layout/index.mjs",
      "require": "./dist/yoga-layout/index.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "lint": "biome check src/"
  },
  "dependencies": {
    "@alcalzone/ansi-tokenize": "^0.3.0",
    "emoji-regex": "^10.6.0",
    "get-east-asian-width": "^1.5.0",
    "semver": "^7.7.4",
    "strip-ansi": "^7.2.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/semver": "^7.7.1",
    "tsup": "^8.5.1",
    "typescript": "~6.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/re-marked/yokai.git",
    "directory": "packages/shared"
  },
  "homepage": "https://github.com/re-marked/yokai",
  "bugs": "https://github.com/re-marked/yokai/issues",
  "keywords": [
    "terminal",
    "cli",
    "tui",
    "yoga",
    "layout"
  ],
  "engines": {
    "node": ">=22.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
