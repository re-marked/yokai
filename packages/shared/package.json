{
  "name": "@yokai/shared",
  "version": "0.3.0",
  "description": "Shared utilities — Yoga layout TS port, logger, env helpers",
  "license": "MIT",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./yoga-layout": {
      "types": "./dist/yoga-layout/index.d.ts",
      "import": "./dist/yoga-layout/index.mjs",
      "require": "./dist/yoga-layout/index.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "lint": "biome check src/"
  },
  "dependencies": {
    "@alcalzone/ansi-tokenize": "*",
    "emoji-regex": "*",
    "get-east-asian-width": "*",
    "semver": "*",
    "strip-ansi": "*"
  },
  "devDependencies": {
    "@types/node": "*",
    "@types/semver": "*",
    "tsup": "*",
    "typescript": "*"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/re-marked/yokai.git",
    "directory": "packages/shared"
  },
  "homepage": "https://github.com/re-marked/yokai",
  "bugs": "https://github.com/re-marked/yokai/issues",
  "keywords": [
    "terminal",
    "cli",
    "tui",
    "yoga",
    "layout"
  ],
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  }
}
